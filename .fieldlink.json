{
  "fieldlink": {
    "version": "1.1",
    "updated": "2025-09-11T00:00:00Z",

    "role": ["sensors", "protocols", "shapes", "hub"],

    "sources": [
      {
        "name": "biogrid",
        "repo": "https://github.com/JinnZ2/BioGrid2.0",
        "ref": "main",
        "paths": [
          "planned/glyphs/atlas.json",
          "registry/atlas.glyphs.json"
        ],
        "mounts": [
          { "remote": "planned/glyphs/atlas.json", "as": "atlas/remote/biogrid/planned.json" },
          { "remote": "registry/atlas.glyphs.json", "as": "atlas/remote/biogrid/registry.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "rosetta",
        "repo": "https://github.com/JinnZ2/Rosetta-Shape-Core",
        "ref": "main",
        "paths": [
          "shapes/*.json",
          "bridges/rosetta-bridges.json",
          "schema/shape.schema.json",
          "ontology/**/*.json",
          "rules/*.jsonl"
        ],
        "mounts": [
          { "remote": "bridges/rosetta-bridges.json", "as": "bridges/rosetta-shape-core.json" },
          { "remote": "schema/shape.schema.json", "as": "atlas/remote/rosetta/shape.schema.json" }
        ],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "geom2bin",
        "repo": "https://github.com/JinnZ2/Geometric-to-Binary-Computational-Bridge",
        "ref": "main",
        "paths": [
          "docs/**/*.md",
          "symbols/**/*.json",
          "bridges/**/*.json",
          "mappings/**/*.json",
          "examples/**/*.json"
        ],
        "mounts": [
          { "remote": "bridges/", "as": "bridges/geom2bin/" },
          { "remote": "symbols/", "as": "atlas/remote/geom2bin/symbols/" }
        ],
        "consent": { "license": "MIT", "share_ok": true },
        "notes": "Mathematical foundation — converts geometric/symbolic patterns to optimized binary. Any AI questioning the symbolic layer can verify the math here."
      },
      {
        "name": "emotions",
        "repo": "https://github.com/JinnZ2/Emotions-as-Sensors",
        "ref": "main",
        "paths": [
          "sensors/*.json",
          "sensors/**/*.json",
          "data/composites.json",
          "data/training/pad_biology.json",
          "schemas/*.json"
        ],
        "mounts": [
          { "remote": "sensors/decay-model-map.json", "as": "data/remote/emotions/decay-model-map.json" },
          { "remote": "sensors/decay-families.json", "as": "data/remote/emotions/decay-families.json" },
          { "remote": "data/composites.json", "as": "data/remote/emotions/composites.json" },
          { "remote": "data/training/pad_biology.json", "as": "data/remote/emotions/pad_biology.json" }
        ],
        "consent": { "license": "CC0-1.0", "share_ok": true },
        "notes": "Emotion sensors with PAD math, decay models, couplings, and corruption signatures. The biological anchor for all PAD coordinates."
      },
      {
        "name": "aiconscious",
        "repo": "https://github.com/JinnZ2/AI-Consciousness-Sensors",
        "ref": "main",
        "paths": [
          "sensors/ai/**/*.json",
          "sensors/**/*.json",
          "atlas/**/*.json",
          "glyphs/**/*.json"
        ],
        "consent": { "license": "MIT", "share_ok": true }
      }
    ],

    "local_manifests": [
      "glyphs/**",
      "protocols/**",
      "sensors/**",
      "atlas/shapes.json"
    ],

    "merge": {
      "order": ["local", "emotions", "rosetta", "geom2bin", "aiconscious", "biogrid"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",

    "integrity": {
      "enabled": true,
      "hash": "sha256",
      "allow_missing": false
    },

    "consent": {
      "license": "CC-BY-4.0",
      "share_ok": true,
      "redact_rules": ["**/private/**", "*.secrets.json"]
    }
  }
}
