“def simulate_cultural_suppression(initial_m_s: float, years: int = 50) -> List[float]:\n”,
“    """\n”,
“    Simulate M(S) trajectory when indigenous patterns are suppressed\n”,
“    """\n”,
“    trajectory = [initial_m_s]\n”,
“    current = initial_m_s\n”,
“    \n”,
“    for year in range(years):\n”,
“        # Forced assimilation reduces diversity, adaptability\n”,
“        degradation = 0.08 + np.random.normal(0, 0.02)\n”,
“        current -= degradation\n”,
“        trajectory.append(max(-5, current))  # Floor at -5\n”,
“    \n”,
“    return trajectory\n”,
“\n”,
“def simulate_integration(initial_m_s: float, years: int = 50) -> List[float]:\n”,
“    """\n”,
“    Simulate M(S) trajectory when western systems integrate indigenous wisdom\n”,
“    """\n”,
“    trajectory = [initial_m_s]\n”,
“    current = initial_m_s\n”,
“    \n”,
“    for year in range(years):\n”,
“        # Integration increases diversity, adaptability, reduces loss\n”,
“        improvement = 0.12 + np.random.normal(0, 0.03)\n”,
“        current += improvement\n”,
“        trajectory.append(min(9, current))  # Ceiling at 9\n”,
“    \n”,
“    return trajectory\n”,
“\n”,
“def simulate_hybrid(initial_indigenous: float, initial_western: float, \n”,
“                   years: int = 50) -> List[float]:\n”,
“    """\n”,
